rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return request.auth != null && userRole() == 'admin';
    }

    function isGf() {
      return request.auth != null && userRole() == 'gf';
    }

    match /timeline_events/{doc} {
      allow read: if true;
      allow write: if isAdmin();
      allow update: if isGf()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['gfNote']);
    }
    match /trips/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }
    match /general/{doc} {
      allow read: if true;
      allow write: if true;
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
