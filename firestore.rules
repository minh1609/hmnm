rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /timeline_events/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /trips/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
